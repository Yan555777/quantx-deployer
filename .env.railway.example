# Railway environment variables for QuantX Deployer.
# Copy to Railway dashboard -> Variables. Do NOT commit real values.

# --- Required ------------------------------------------------------------
# Provided automatically when you attach the Railway PostgreSQL plugin.
DATABASE_URL=postgresql://user:pass@host:port/railway

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=<64-hex-chars>

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=<44-char-base64>

# Set by Railway; read-only.
# RAILWAY_ENVIRONMENT=production

# --- LongPort OAuth ------------------------------------------------------
LONGPORT_OAUTH_CLIENT_ID=81d2945e-f0b0-4eda-89a8-ca8677ebea1d
# Registration token (used offline to update client metadata, not at runtime)
LONGPORT_OAUTH_REGISTRATION_TOKEN=hwL836gPwzoH39EQBnYTW8EKqQDpXl/M/DwABaaKZdA=
# Override if redirect URI differs from the default Railway URL
# LONGPORT_OAUTH_REDIRECT_URI=https://quantxdeployer.railway.app/callback/longport

# --- Options data (Cloudflare R2) ---------------------------------------
R2_ENDPOINT=https://7f835882a6c11ee760fe4e96eb8cbef2.r2.cloudflarestorage.com
R2_ACCESS_KEY=<set-in-railway>
R2_SECRET_KEY=<set-in-railway>
R2_BUCKET=options-data

# --- Optional -----------------------------------------------------------
# CENTRAL_API_URL=https://your-other-service.railway.app
# OPTIONS_USE_SLIM_DATA=1
# OPTIONS_CACHE_DIR=/data/options_cache
# PORT=8080   # Railway sets this automatically
